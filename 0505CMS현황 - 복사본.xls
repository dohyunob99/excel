

<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40">

<head>
<style type="text/css">
body {font-family:tahoma;font-size: 12px}
table {padding:2px;border-spacing:0px;font-family:tahoma;font-size: 12px;border-collapse: collapse}
input,textarea,Select {font-family:tahoma;font-size: 12px;border-collapse: collapse;}
.bgc {background-color:#dddddd}
.bgct {background-color:#FAF082}
td {text-align:center}
br {mso-data-placement:same-cell;}
.list5 {border-top:2px solid #383838;border-bottom:1px solid #e5e5e5;width:100%;border:1px solid #000;}
.list5 thead th {height:39px;color:#777;font-size:11px;background:#f5f5f5;border-right:1px solid #000;border-bottom:1px solid #e5e5e5;}
.list5 tbody th, .list5 tbody td {border-right:1px solid #e1e1e1;border-top:1px solid #e1e1e1;text-align:center;height:40px;color:#666;font-size:11px;}
.list5 tbody .a_l{text-align:left; padding:0 15px; color:#666;}
.list5 tbody td a.title01 {text-align:left;padding:0 15px;white-space:nowrap;display:block;width:450px; color:#666;overflow:hidden;text-overflow:ellipsis;}
.list5 tbody td a.title02 {text-align:left;padding:0 15px;white-space:nowrap;display:block;color:#666;overflow:hidden;text-overflow:ellipsis;}
.list5 tbody .conts01 {text-align:left;padding:10px 10px;}
.list5 tbody .ta_r {padding:0px 0; text-align:left; line-height:20px;}
.list5 tbody td a span.comment_num {color:#F44336;font-weight:bold;}
.list5 tbody td.bold {font-weight:bold;}
.list5 .check_p{text-align:center;  color:#0000FF; font-weight:bold;}

.list3 {border-top:2px solid #383838;border-bottom:1px solid #e5e5e5;width:100%;}
.list3 thead th {height:39px;color:#777;font-size:13px;background:#f5f5f5;}
.list3 tbody th, .list3 tbody td {border-top:1px solid #e1e1e1;text-align:center;color:#666;font-size:13px;}
.list3 tbody td.conts01 {text-align:left;padding:13px 15px;}
.list3 tbody td.bold {font-weight:bold;}
.list3 tbody th {font-weight:normal;}
.list3 tbody td {border-left:1px solid #e1e1e1;}

.write3{width:100%; border-top:4px solid #383838;}
.write3 table{width:750px;}
.write3 th{padding:10px 0;letter-spacing:-1px; font-size:13px; color:#454545;border-bottom:1px solid #e5e5e5; background:#f5f5f5;height:40px;}
.write3 td{padding:10px 0;border-bottom:1px solid #e5e5e5;text-align:center;vertical-align:middle; font-size:13px;line-height:20px;}
.write3 input[type=text], input[type=password]{padding:5px 0;border:1px solid #d9d9d9;color:#4d4d4d;}
.write3 textarea{padding:5px 0;border:1px solid #d9d9d9;color:#4d4d4d;}
.write3 td input[type=file] {font:normal 13px 'Nanum Gothic', serif, sans-serif;margin-bottom:2px;}
.write3 td a {color:#666;}
.write3 input.datepicker{background-color:#F9F8F7;display:inline-block;vertical-align:middle;}
.write3 td .calendar {display:inline-block;width:30px;height:28px;vertical-align:middle;margin-left:-1px;}
.write3 .edu_point{text-align:center; color:blue;}
.write3 .total_p{text-align:center; font-size:20px; color:red; font-weight:bold;}
.write3 .check_p{text-align:center;  color:#0000FF; font-weight:bold;}
.list {border-top:2px solid #383838;border-bottom:1px solid #e5e5e5;width:750px;}
.list thead th {height:39px;color:#777;font-size:13px;background:#f5f5f5;border-right:1px solid #e1e1e1;}
.list tbody th {border-right:1px solid #e1e1e1;border-top:1px solid #e1e1e1;text-align:center;height:40px;color:#666;font-size:13px;} 
.list tbody td {border-right:1px solid #e1e1e1;border-top:1px solid #e1e1e1;text-align:center;height:40px;color:#666;font-size:13px;}
.list tbody .a_l{text-align:left; padding:0 15px; color:#666;}
.list tbody td a.title01 {text-align:left;padding:0 15px;white-space:nowrap;display:block;width:450px; color:#666;overflow:hidden;text-overflow:ellipsis;}
.list tbody td a.title02 {text-align:left;padding:0 15px;white-space:nowrap;display:block;color:#666;overflow:hidden;text-overflow:ellipsis;}
.list tbody .conts01 {text-align:left;padding:10px 10px;}
.list tbody .ta_r {padding:0px 0; text-align:left; line-height:20px;}
.list tbody td a span.comment_num {color:#F44336;font-weight:bold;}
.list tbody td.bold {font-weight:bold;}
.list .Dend {border-bottom:1px solid #e5e5e5;}
.list .check_p{text-align:center;  color:#0000FF; font-weight:bold;}
</style>

</head>
